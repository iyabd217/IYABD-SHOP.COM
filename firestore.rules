rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() { return request.auth != null; }
    function isAdmin() { 
      return isSignedIn() && (
        request.auth.token.get('admin', false) == true ||
        request.auth.token.get('email', '') == "yousuf60679@gmail.com" ||
        request.auth.token.get('email', '') == "admin.iyabd@gmail.com" ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }
    
    match /products/{id} { allow read: if true; allow write: if isAdmin(); }
    match /flash_sales/{id} { allow read: if true; allow write: if isAdmin(); }
    match /config/{id} { allow read: if true; allow write: if isAdmin(); }
    match /category_banners/{id} { allow read: if true; allow write: if isAdmin(); }
    match /categories/{id} { allow read: if true; allow write: if isAdmin(); }
    match /banners/{id} { allow read: if true; allow write: if isAdmin(); }
    match /hero_banners/{id} { allow read: if true; allow write: if isAdmin(); }
    match /brands/{id} { allow read: if true; allow write: if isAdmin(); }
    match /blog_posts/{id} { allow read: if true; allow write: if isAdmin(); }
    match /reviews/{id} { allow read: if true; allow write: if isSignedIn(); }
    match /users/{userId} { allow read, write: if isSignedIn() && (request.auth.uid == userId || isAdmin()); }
    match /orders/{orderId} {
      allow create: if true;
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || resource.data.userEmail == request.auth.token.get('email', '') || isAdmin());
      allow update, delete: if isAdmin();
    }
    match /wishlist/{wishId} { allow read, write: if isSignedIn() && (request.auth.uid == wishId || isAdmin()); }
    match /support_messages/{id} { allow create: if true; allow read, write: if isAdmin(); }
    match /activity_logs/{id} { allow read, create: if isAdmin(); }
    match /coupons/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /admins/{id} { allow read: if isAdmin(); }
    
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
