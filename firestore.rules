rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() { return request.auth != null; }
    function isAdmin() { 
      return isSignedIn() && (
        request.auth.uid == 'admin_system' ||
        request.auth.token.admin == true ||
        (("email" in request.auth.token) && (request.auth.token.email == "yousuf60679@gmail.com" || request.auth.token.email == "admin.iyabd@gmail.com")) ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }
    
    match /products/{id} { allow read: if true; allow write: if isAdmin(); }
    match /flash_sales/{id} { allow read: if true; allow write: if isAdmin(); }
    match /config/{id} { allow read: if true; allow write: if isAdmin(); }
    match /category_banners/{id} { allow read: if true; allow write: if isAdmin(); }
    match /categories/{id} { allow read: if true; allow write: if isAdmin(); }
    match /banners/{id} { allow read: if true; allow write: if isAdmin(); }
    match /hero_banners/{id} { allow read: if true; allow write: if isAdmin(); }
    match /brands/{id} { allow read: if true; allow write: if isAdmin(); }
    match /blog_posts/{id} { allow read: if true; allow write: if isAdmin(); }
    match /reviews/{id} { allow read, write: if true; }
    match /users/{userId} { allow read, write: if true; }
    match /orders/{orderId} {
      allow create: if true;
      allow read: if true;
      allow update, delete: if isAdmin();
    }
    match /wishlist/{wishId} { allow read, write: if true; }
    match /support_messages/{id} { allow create, read: if true; allow write: if isAdmin(); }
    match /activity_logs/{id} { allow read, create: if isAdmin(); }
    match /coupons/{id} { allow read: if true; allow write: if isAdmin(); }
    match /admins/{id} { allow read: if isAdmin(); }
    match /customer-emails/{id} { allow read, write: if isAdmin(); }
    
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
