rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net (Default Deny)
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Core Primitives ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == "yousuf60679@gmail.com" ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() > 0 && id.size() <= 128;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Validation Blueprints ---

    function isValidProduct(data) {
      return data.name is string && data.name.size() > 0 && 
             data.price is number && data.price >= 0;
    }

    function isValidCategory(data) {
      return data.name is string && data.name.size() > 0;
    }

    function isValidBanner(data) {
      return data.title is string && data.title.size() > 0;
    }

    function isValidOrder(data) {
      return data.items is list && data.items.size() > 0 &&
             data.total is number && data.total >= 0 &&
             (data.userId == 'guest' || (isSignedIn() && data.userId == request.auth.uid));
    }

    function isActionUpdate(allowedFields) {
      return incoming().diff(existing()).affectedKeys().hasOnly(allowedFields);
    }

    // --- Collection Rules ---

    // Config - Public Read, Admin Write
    match /config/{configId} {
      allow get: if true;
      allow list: if true;
      allow write: if isAdmin();
    }

    // Banners - Public Read, Admin Write
    match /banners/{bannerId} {
      allow get: if true;
      allow list: if true;
      allow write: if isAdmin() && isValidBanner(incoming());
    }

    // Products - Public Read, Admin Write
    match /products/{productId} {
      allow get: if true;
      allow list: if true;
      allow create: if isAdmin() && isValidProduct(incoming());
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Categories - Public Read, Admin Write
    match /categories/{categoryId} {
      allow read, list: if true;
      allow create: if isAdmin() && isValidId(categoryId) && isValidCategory(incoming());
      allow update: if isAdmin() && isValidId(categoryId) && isValidCategory(incoming());
      allow delete: if isAdmin() && isValidId(categoryId);
    }

    // Brands - Public Read, Admin Write
    match /brands/{brandId} {
      allow read, list: if true;
      allow write: if isAdmin() && isValidId(brandId);
    }

    // Blog Posts - Public Read, Admin Write
    match /blog_posts/{postId} {
      allow read, list: if true;
      allow write: if isAdmin() && isValidId(postId);
    }

    // Orders - Private to Owner and Admins
    match /orders/{orderId} {
      allow get: if isValidId(orderId) && (isAdmin() || (isSignedIn() && existing().userId == request.auth.uid));
      allow list: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isValidId(orderId) && isValidOrder(incoming());
      allow update: if isAdmin() && isValidId(orderId);
      allow delete: if isAdmin() && isValidId(orderId);
    }

    // Coupons - Admin only
    match /coupons/{couponId} {
      allow read, list, write: if isAdmin() && isValidId(couponId);
    }

    // Users - Owner and Admin
    match /users/{userId} {
      allow read: if isValidId(userId) && (isOwner(userId) || isAdmin());
      allow create: if isValidId(userId) && isOwner(userId);
      allow update: if isValidId(userId) && (isOwner(userId) && !incoming().diff(existing()).affectedKeys().hasAny(['role']) || isAdmin());
    }

    // Activity Logs - Admin only
    match /activity_logs/{logId} {
      allow read, list, write: if isAdmin() && isValidId(logId);
    }

    // Support Messages - Anonymous Create, Admin Read
    match /support_messages/{messageId} {
      allow create: if isValidId(messageId);
      allow read, list, write: if isAdmin() && isValidId(messageId);
    }

    // Admins
    match /admins/{userId} {
      allow read: if isValidId(userId) && isSignedIn();
      allow write: if false;
    }
    
    // Reviews
    match /reviews/{reviewId} {
      allow read, list: if true;
      allow create: if isValidId(reviewId) && isSignedIn();
      allow update, delete: if isValidId(reviewId) && (isAdmin() || (isSignedIn() && existing().userId == request.auth.uid));
    }
  }
}
